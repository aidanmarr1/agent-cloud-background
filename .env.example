LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_EFFORT=minimal
DEEPSEEK_THINKING_ENABLED=false

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_REASONING_EFFORT=minimal
OPENROUTER_REASONING_EXCLUDE=true

# Web and image search.
SERPER_API_KEY=
SERPER_BASE_URL=https://google.serper.dev

# Turso database. Keep real values only in .env.local.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Auth.js. Generate with: npx auth secret
AUTH_SECRET=
# Signed internal readiness/smoke endpoints. Generate a separate random value
# for production so smoke tests do not need your session-signing secret.
AGENT_INTERNAL_HEALTH_SECRET=
# Vercel is trusted automatically; set true only behind a trusted proxy elsewhere.
AUTH_TRUST_HOST=false

# Public signup is disabled by default. Disabled signups create admin-reviewed access requests.
AGENT_PUBLIC_SIGNUP=false

AGENT_APP_URL=

# Attachment blob storage. Use Turso in production so uploads survive serverless restarts.
AGENT_STORAGE_DRIVER=turso
AGENT_STORAGE_DIR=.agent-storage

# Real cloud background execution. When set to external, /api/chat enqueues
# tasks in Turso and a separate cloud worker must run `npm run worker:cloud`.
# Leave unset for local/dev in-process execution.
AGENT_TASK_WORKER_MODE=
AGENT_TASK_QUEUE_NAME=default
AGENT_TASK_WORKER_ID=
AGENT_TASK_WORKER_POLL_MS=100
AGENT_TASK_WORKER_HEARTBEAT_MS=15000
AGENT_TASK_WORKER_STALE_MS=60000
AGENT_TASK_WORKER_MAX_ATTEMPTS=3
AGENT_REQUIRE_TASK_WORKER_HEARTBEAT=true
AGENT_REQUIRE_HOSTED_TASK_WORKER=false
# Optional release guard. Set the same AGENT_DEPLOYMENT_VERSION on web and
# worker, then set AGENT_REQUIRE_WORKER_DEPLOYMENT_VERSION=true to reject stale
# workers from older deployments.
AGENT_DEPLOYMENT_VERSION=
AGENT_REQUIRE_WORKER_DEPLOYMENT_VERSION=false

# E2B task sandbox provider. Set AGENT_REQUIRE_HOSTED_TASK_WORKER=true only
# when a hosted worker is live; false allows this machine's worker to claim tasks.
AGENT_SANDBOX_PROVIDER=e2b
E2B_API_KEY=
E2B_TEMPLATE_ID=
AGENT_E2B_SANDBOX_TIMEOUT_MS=3600000
AGENT_E2B_COMMAND_TIMEOUT_MS=120000
AGENT_E2B_ALLOW_INTERNET=true
AGENT_E2B_PAUSE_ON_TASK_END=false
AGENT_E2B_KILL_ON_RESET=true
AGENT_E2B_BROWSER_PORT=9222
AGENT_E2B_BROWSER_START_TIMEOUT_MS=30000
AGENT_E2B_BROWSER_LAUNCH_TIMEOUT_MS=30000
AGENT_E2B_WARM_POOL_ENABLED=false
AGENT_E2B_VERIFY_ON_WORKER_STARTUP=false
AGENT_E2B_VERIFY_BROWSER_ON_WORKER_STARTUP=false
AGENT_E2B_BROWSER_BOOTSTRAP_COMMAND=
