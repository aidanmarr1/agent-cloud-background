    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-react-hooks": "^7.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.13"
  }
