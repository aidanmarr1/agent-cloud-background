    "cloud:e2b-smoke": "node scripts/e2b-template-smoke.mjs",
    "cloud:queue": "node scripts/cloud-queue.mjs",
    "cloud:status": "node scripts/cloud-production-status.mjs",
    "cloud:finish-setup": "node scripts/cloud-finish-setup.mjs",
    "cloud:preflight": "node scripts/cloud-preflight.mjs",
    "cloud:check": "node scripts/cloud-readiness.mjs",
