    "e2b": "^2.27.1",
    "esbuild": "^0.28.0",
    "highlight.js": "^11.11.1",
    "idb-keyval": "^6.2.2",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.0",
    "katex": "^0.16.39",
    "mammoth": "^1.12.0",
    "mermaid": "^11.13.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.31",
    "pdf-parse": "^1.1.1",
